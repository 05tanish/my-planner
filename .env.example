# ─────────────────────────────────────────────
# DATABASE — Neon DB (https://console.neon.tech)
# ─────────────────────────────────────────────
# Pooled connection (app runtime)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true

# Direct connection (Prisma migrations only)
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─────────────────────────────────────────────
# AUTH
# ─────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-minimum-32-characters-long
JWT_EXPIRY=7d
ALLOWED_EMAILS=your@email.com

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────
# EMAIL — Resend (https://resend.com)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=DevOS <onboarding@resend.dev>

# ─────────────────────────────────────────────
# TELEGRAM (optional — for reminders)
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# SUPABASE (optional — for file storage)
# Get from Supabase Dashboard > Project Settings > API
# ─────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=devos-files

# ─────────────────────────────────────────────
# REDIS — Upstash (https://upstash.com)
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-upstash-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

