# ────────────────────────────────────────
# DevOS — .gitignore
# ────────────────────────────────────────

# Environment files — NEVER commit these
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.local

# Node
node_modules/
frontend/node_modules/
backend/node_modules/

# Build outputs
frontend/dist/
backend/dist/

# Prisma generated
backend/prisma/migrations/*.sql.bak

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids
*.pid
*.seed

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V3
.Trashes
ehthumbs.db
Thumbs.db

# Editor/IDE
.vscode/settings.json
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# TypeScript cache
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# Uploads / temp files
uploads/
tmp/

# Docker volumes
.docker/

# Vercel
.vercel

# Testing
coverage/
