// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  password             String
  role                 Role      @default(USER)
  emailVerified        Boolean   @default(false)
  emailVerifyToken     String?
  emailVerifyExpiry    DateTime?
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  profile              Profile?
  sessions             Session[]
  tasks                Task[]
  dsaProblems          DsaProblem[]
  dsaDailyGoals        DsaDailyGoal[]
  notes                Note[]
  resources            Resource[]
  resourceFolders      ResourceFolder[]
  books                Book[]
  jobs                 Job[]
  learningEntries      LearningEntry[]
  placementNotes       PlacementNote[]
  githubActivities     GithubActivity[]
  reminders            Reminder[]
  dashboardLayouts     DashboardLayout[]
  analyticsSnapshots   AnalyticsSnapshot[]
  productivityLogs     ProductivityLog[]
  projects             Project[]
  interviewQuestions   InterviewQuestion[]
  githubStats          GitHubStats[]
  knowledgeCaptures    KnowledgeCapture[]
  youtubeVideos        YouTubeVideo[]
  habitLogs            HabitLog[]
  dailyAIMentorReports DailyAIMentorReport[]
  weeklyReviews        WeeklyReview[]
  opportunities        Opportunity[]
  hackathons           Hackathon[]
  alerts               Alert[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PROFILE
// ─────────────────────────────────────────────

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  name           String
  bio            String?
  avatarUrl      String?
  logoUrl        String?
  githubUsername String?
  linkedinUrl    String?
  backupEmail    String?
  socialLinks    Json?
  notifEmail     Boolean  @default(true)
  notifTelegram  Boolean  @default(false)
  telegramChatId String?
  reminderTime   String   @default("09:00")
  telegramNotifInterval Int @default(1)
  lastTelegramSent      DateTime?
  telegramLinkToken  String?
  telegramLinkExpiry DateTime?
  leetcodeUsername   String?
  gfgUsername        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// DASHBOARD
// ─────────────────────────────────────────────

model DashboardLayout {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Default")
  isDefault Boolean  @default(false)
  layout    Json     // react-grid-layout layout array
  widgets   Json     // widget config { id, type, visible, config }[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// DSA
// ─────────────────────────────────────────────

enum DsaPlatform {
  LEETCODE
  GFG
  CODEFORCES
  CODECHEF
  HACKERRANK
}

enum DsaDifficulty {
  EASY
  MEDIUM
  HARD
}

enum DsaTopic {
  ARRAYS
  STRINGS
  HASHING
  LINKED_LIST
  STACK
  QUEUE
  TREE
  BST
  HEAP
  GRAPH
  DP
  GREEDY
  BACKTRACKING
  TRIE
  SEGMENT_TREE
  BINARY_SEARCH
  SLIDING_WINDOW
  TWO_POINTERS
}

model DsaProblem {
  id             String        @id @default(cuid())
  userId         String
  name           String
  difficulty     DsaDifficulty
  platform       DsaPlatform
  problemUrl     String?
  solutionUrl    String?
  code           String?       // solution code
  videoLinks     String[]      // YouTube/video links
  notes          String?
  tags           String[]
  topics         DsaTopic[]
  personalRating Int?          @db.SmallInt // 1-5
  timeTaken      Int?          // minutes
  mistakes       String?
  solvedAt       DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions      DsaRevision[]

  @@index([userId])
}

model DsaRevision {
  id          String     @id @default(cuid())
  problemId   String
  dueDate     DateTime
  completedAt DateTime?
  dayInterval Int        // 1, 3, 7, 15, 30, 60, 90
  createdAt   DateTime   @default(now())
  problem     DsaProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// NOTES
// ─────────────────────────────────────────────

model Note {
  id          String          @id @default(cuid())
  userId      String
  title       String
  content     String          @default("")
  category    String?
  folderPath  String?         // e.g. "Backend/NodeJS"
  isPinned    Boolean         @default(false)
  isFavorite  Boolean         @default(false)
  isArchived  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags        NoteTag[]
  attachments NoteAttachment[]

  @@index([userId])
}

model NoteTag {
  id     String @id @default(cuid())
  noteId String
  tag    String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, tag])
}

model NoteAttachment {
  id        String   @id @default(cuid())
  noteId    String
  url       String
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// TASKS / PLANNER
// ─────────────────────────────────────────────

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskScope {
  DAILY
  WEEKLY
  MONTHLY
}

model Task {
  id            String       @id @default(cuid())
  userId        String
  title         String
  description   String?
  priority      TaskPriority @default(MEDIUM)
  status        TaskStatus   @default(TODO)
  scope         TaskScope    @default(DAILY)
  category      String?      // DSA, Backend, DevOps, Blockchain, Placement, Personal, Project, Learning
  dueDate       DateTime?
  reminderAt    DateTime?
  isRecurring   Boolean      @default(false)
  recurrRule    String?      // cron/rrule expression
  estimatedTime Int?         // in minutes (Phase 5)
  actualTime    Int?         // in minutes (Phase 5)
  tags          String[]     // Phase 4
  completedAt   DateTime?    // Track completion time
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([dueDate])
}

// ─────────────────────────────────────────────
// REMINDERS
// ─────────────────────────────────────────────

enum ReminderType {
  DSA
  SYSTEM_DESIGN
  BACKEND_LEARNING
  GITHUB_PUSH
  JOB_APPLICATION
  BOOK_READING
  CUSTOM
}

model Reminder {
  id        String       @id @default(cuid())
  userId    String
  type      ReminderType
  channels  String[]     // ["EMAIL", "TELEGRAM"]
  message   String
  cronExpr  String
  isActive  Boolean      @default(true)
  lastSent  DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// JOB TRACKER
// ─────────────────────────────────────────────

enum JobStatus {
  WISHLIST
  APPLIED
  OA
  INTERVIEW
  REJECTED
  OFFER
  SELECTED
}

model Job {
  id          String    @id @default(cuid())
  userId      String
  company     String
  role        String
  jobUrl      String?
  status      JobStatus @default(APPLIED)
  appliedDate DateTime  @default(now())
  location    String?
  salary      String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// LEARNING HUB
// ─────────────────────────────────────────────

enum LearningCategory {
  BACKEND
  DEVOPS
  BLOCKCHAIN
  AUTOMATION
  SYSTEM_DESIGN
  AI
}

enum LearningResourceType {
  NOTE
  VIDEO
  ARTICLE
  PDF
  IMAGE
  CHEAT_SHEET
  PROJECT
  ROADMAP
}

model LearningEntry {
  id          String               @id @default(cuid())
  userId      String
  title       String
  category    LearningCategory
  type        LearningResourceType
  content     String?
  url         String?
  fileUrl     String?
  tags        String[]
  durationMin Int?                 // minutes spent
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// RESOURCE VAULT
// ─────────────────────────────────────────────

enum ResourceType {
  YOUTUBE
  WEBSITE
  PDF
  IMAGE
  COURSE
  PLAYLIST
  BLOG
  DOCUMENTATION
  CHEAT_SHEET
}

model ResourceFolder {
  id        String           @id @default(cuid())
  userId    String
  name      String
  parentId  String?
  createdAt DateTime         @default(now())
  resources Resource[]
  children  ResourceFolder[] @relation("FolderHierarchy")
  parent    ResourceFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Resource {
  id          String          @id @default(cuid())
  userId      String
  title       String
  type        ResourceType
  url         String?
  fileUrl     String?
  folderId    String?
  tags        String[]
  description String?
  status      String          @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  isFavorite  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder      ResourceFolder? @relation(fields: [folderId], references: [id])

  @@index([userId])
}

// ─────────────────────────────────────────────
// PLACEMENT PREP
// ─────────────────────────────────────────────

enum PlacementSection {
  DBMS
  OS
  CN
  OOP
  SYSTEM_DESIGN
  APTITUDE
  QUANT
  REASONING
  VERBAL
  HR
  INTERVIEW_EXPERIENCE
}

enum PlacementResourceType {
  NOTE
  PDF
  IMAGE
  FLASHCARD
  IMPORTANT_QUESTION
}

model PlacementNote {
  id         String                @id @default(cuid())
  userId     String
  section    PlacementSection
  title      String
  content    String?
  type       PlacementResourceType @default(NOTE)
  fileUrl    String?
  tags       String[]
  isPinned   Boolean               @default(false)
  isFavorite Boolean               @default(false)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// BOOK LIBRARY
// ─────────────────────────────────────────────

enum BookCategory {
  DSA
  BACKEND
  DEVOPS
  BLOCKCHAIN
  SYSTEM_DESIGN
  PRODUCTIVITY
}

enum ReadingStatus {
  WANT_TO_READ
  READING
  COMPLETED
  PAUSED
}

model Book {
  id            String        @id @default(cuid())
  userId        String
  title         String
  author        String?
  category      BookCategory
  coverUrl      String?
  fileUrl       String?
  notes         String?
  highlights    String?
  totalPages    Int?
  currentPage   Int           @default(0)
  readingStatus ReadingStatus @default(WANT_TO_READ)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// GITHUB TRACKER
// ─────────────────────────────────────────────

model GithubActivity {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @db.Date
  commits      Int      @default(0)
  repositories String[]
  features     String?
  bugsFix      String?
  upcomingWork String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─────────────────────────────────────────────
// PRODUCTIVITY TRACKER
// ─────────────────────────────────────────────

model ProductivityLog {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date
  studyMinutes    Int      @default(0)
  codingMinutes   Int      @default(0)
  projectMinutes  Int      @default(0)
  readingMinutes  Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─────────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────────

model AnalyticsSnapshot {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date
  dsaSolved       Int      @default(0)
  revisionsCount  Int      @default(0)
  learningMinutes Int      @default(0)
  githubCommits   Int      @default(0)
  tasksCompleted  Int      @default(0)
  jobsApplied     Int      @default(0)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─────────────────────────────────────────────
// DSA DAILY GOAL
// ─────────────────────────────────────────────

model DsaDailyGoal {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  completed   Boolean  @default(false)
  solvedCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ─────────────────────────────────────────────
// PROJECT HUB (Phase 1)
// ─────────────────────────────────────────────

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  IDEA
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Project {
  id                    String          @id @default(cuid())
  userId                String
  name                  String
  description           String?
  status                ProjectStatus   @default(ACTIVE)
  priority              ProjectPriority @default(MEDIUM)
  startDate             DateTime?
  endDate               DateTime?
  githubUrl             String?
  deploymentUrl         String?
  documentationUrl      String?
  blogUrl               String?
  techStack             String[]
  architectureNotes     String?
  completionPercentage  Int             @default(0)
  currentMilestone      String?
  nextMilestone         String?
  resumeBullets         String[]
  interviewTalkingPoints String[]
  challengesSolved      String[]
  keyLearnings          String[]
  commits               Int             @default(0)
  codingHours           Float           @default(0)
  deploymentCount       Int             @default(0)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  features              ProjectFeature[]
  
  @@index([userId])
  @@index([status])
}

enum FeatureStatus {
  COMPLETED
  PENDING
  FUTURE
}

model ProjectFeature {
  id          String        @id @default(cuid())
  projectId   String
  name        String
  description String?
  status      FeatureStatus @default(PENDING)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
}

// ─────────────────────────────────────────────
// INTERVIEW VAULT (Phase 2)
// ─────────────────────────────────────────────

enum InterviewCategory {
  BACKEND
  DEVOPS
  BLOCKCHAIN
  HR
  PROJECT_QUESTIONS
}

enum InterviewSubCategory {
  // Backend
  REST_APIS
  AUTHENTICATION
  JWT
  OAUTH
  DATABASE_DESIGN
  SCALABILITY
  CACHING
  QUEUES
  MICROSERVICES
  
  // DevOps
  LINUX
  DOCKER
  KUBERNETES
  CI_CD
  NGINX
  MONITORING
  TERRAFORM
  
  // Blockchain
  SMART_CONTRACTS
  EVM
  SOLIDITY
  SECURITY
  CONSENSUS
  DEFI_CONCEPTS
  
  // HR
  TELL_ME_ABOUT_YOURSELF
  STRENGTHS
  WEAKNESSES
  CONFLICT_HANDLING
  TEAMWORK
  LEADERSHIP
  
  // Project
  CHAT_APP
  DEVOS
  BLOCKCHAIN_PROJECTS
  OTHER
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

model InterviewQuestion {
  id              String              @id @default(cuid())
  userId          String
  category        InterviewCategory
  subCategory     InterviewSubCategory?
  question        String
  shortAnswer     String?
  detailedAnswer  String?
  notes           String?
  tags            String[]
  difficulty      QuestionDifficulty  @default(MEDIUM)
  revisionCount   Int                 @default(0)
  lastRevisedAt   DateTime?
  isFavorite      Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([category])
}

// ─────────────────────────────────────────────
// BULK TASK MANAGEMENT (Phase 4)
// ─────────────────────────────────────────────

enum BulkTaskCategory {
  DSA
  BACKEND
  DEVOPS
  BLOCKCHAIN
  PLACEMENT
  PERSONAL
  PROJECT
  LEARNING
}

// Extended Task model to support bulk operations and time tracking
// Note: Added fields to existing Task model via migration

// ─────────────────────────────────────────────
// GITHUB PRODUCTIVITY (Phase 6)
// ─────────────────────────────────────────────

model GitHubStats {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date
  dailyCommits    Int      @default(0)
  weeklyCommits   Int      @default(0)
  monthlyCommits  Int      @default(0)
  currentStreak   Int      @default(0)
  longestStreak   Int      @default(0)
  repositories    String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
  @@index([userId])
}

// ─────────────────────────────────────────────
// KNOWLEDGE CAPTURE (Phase 7)
// ─────────────────────────────────────────────

enum KnowledgeSourceType {
  YOUTUBE
  GITHUB_REPO
  ARTICLE
  BLOG
  TWEET
  DOCUMENTATION
  OTHER
}

model KnowledgeCapture {
  id              String              @id @default(cuid())
  userId          String
  sourceType      KnowledgeSourceType
  sourceUrl       String
  title           String
  summary         String?
  keyConcepts     String[]
  notes           String?
  tags            String[]
  linkedDsaTopics DsaTopic[]
  linkedProjects  String[]            // Project IDs
  linkedQuestions String[]            // Interview Question IDs
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([sourceType])
}

// ─────────────────────────────────────────────
// YOUTUBE LEARNING TRACKER (Phase 9)
// ─────────────────────────────────────────────

enum VideoStatus {
  WATCH_LATER
  WATCHING
  COMPLETED
}

model YouTubeVideo {
  id                  String       @id @default(cuid())
  userId              String
  title               String
  channel             String
  url                 String
  duration            Int?         // in seconds
  status              VideoStatus  @default(WATCH_LATER)
  keyConcepts         String[]
  notes               String?
  importantTimestamps Json?        // [{time: "2:30", note: "Key concept"}]
  codeSnippets        String?
  completionPercent   Int          @default(0)
  revisionCount       Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────
// HABIT HEATMAP (Phase 10)
// ─────────────────────────────────────────────

enum HabitType {
  DSA
  CODING
  READING
  EXERCISE
  JOB_APPLICATIONS
  LEARNING
  COMMITS
}

model HabitLog {
  id          String     @id @default(cuid())
  userId      String
  date        DateTime   @db.Date
  habitType   HabitType
  completed   Boolean    @default(false)
  count       Int        @default(0)  // for countable habits
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date, habitType])
  @@index([userId])
}

// ─────────────────────────────────────────────
// AI MENTOR (Phase 11)
// ─────────────────────────────────────────────

model DailyAIMentorReport {
  id                String   @id @default(cuid())
  userId            String
  date              DateTime @db.Date
  tasksCompleted    Int
  dsaSolved         Int
  codingHours       Float
  commits           Int
  applicationsSent  Int
  achievements      String[]
  weaknesses        String[]
  missedGoals       String[]
  tomorrowFocus     String[]
  priorityTasks     String[]
  aiAnalysis        String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
  @@index([userId])
}

// ─────────────────────────────────────────────
// WEEKLY REVIEW (Phase 12)
// ─────────────────────────────────────────────

model WeeklyReview {
  id                  String   @id @default(cuid())
  userId              String
  weekStartDate       DateTime @db.Date
  weekEndDate         DateTime @db.Date
  codingHours         Float
  dsaCount            Int
  projectsProgress    Json     // {projectId: progress%}
  applicationsSent    Int
  commits             Int
  learningHours       Float
  biggestWin          String?
  biggestBottleneck   String?
  improvementAreas    String[]
  actionPlan          String[]
  aiInsights          String?
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, weekStartDate])
  @@index([userId])
}

// ─────────────────────────────────────────────
// OPPORTUNITY RADAR (Phase 13)
// ─────────────────────────────────────────────

enum OpportunityCategory {
  INTERNSHIP
  HACKATHON
  FELLOWSHIP
  OPEN_SOURCE_PROGRAM
  MENTORSHIP
  CONFERENCE
}

enum OpportunityStatus {
  DISCOVERED
  INTERESTED
  APPLIED
  ACCEPTED
  REJECTED
  COMPLETED
}

model Opportunity {
  id              String              @id @default(cuid())
  userId          String
  name            String
  category        OpportunityCategory
  organization    String?
  description     String?
  url             String?
  deadline        DateTime?
  status          OpportunityStatus   @default(DISCOVERED)
  applicationStage String?
  notes           String?
  tags            String[]
  reminderSet     Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([category])
  @@index([deadline])
}

// ─────────────────────────────────────────────
// HACKATHON HUB (Phase 14)
// ─────────────────────────────────────────────

enum HackathonStatus {
  REGISTERED
  BUILDING
  SUBMITTED
  RESULTS_AWAITED
  WON
  PARTICIPATED
}

model Hackathon {
  id              String          @id @default(cuid())
  userId          String
  name            String
  teamMembers     String[]
  idea            String?
  techStack       String[]
  submissionLink  String?
  githubUrl       String?
  demoUrl         String?
  deadline        DateTime?
  status          HackathonStatus @default(REGISTERED)
  prize           String?
  learnings       String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────
// HIGH PRIORITY ALERTS (Phase 15)
// ─────────────────────────────────────────────

enum AlertLevel {
  NORMAL
  HIGH
  CRITICAL
}

enum AlertType {
  OVERDUE_TASK
  HIGH_PRIORITY_TASK
  DEADLINE_24H
  UNFINISHED_WEEKLY_GOAL
  MISSED_DSA_GOAL
  NO_COMMITS_TODAY
  NO_APPLICATIONS_THIS_WEEK
}

model Alert {
  id          String      @id @default(cuid())
  userId      String
  type        AlertType
  level       AlertLevel  @default(NORMAL)
  title       String
  message     String
  actionUrl   String?
  dismissed   Boolean     @default(false)
  notified    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, dismissed])
  @@index([level])
}

