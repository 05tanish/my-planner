// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  password             String
  role                 Role      @default(USER)
  emailVerified        Boolean   @default(false)
  emailVerifyToken     String?
  emailVerifyExpiry    DateTime?
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  profile              Profile?
  sessions             Session[]
  tasks                Task[]
  dsaProblems          DsaProblem[]
  dsaDailyGoals        DsaDailyGoal[]
  notes                Note[]
  resources            Resource[]
  resourceFolders      ResourceFolder[]
  books                Book[]
  jobs                 Job[]
  learningEntries      LearningEntry[]
  placementNotes       PlacementNote[]
  githubActivities     GithubActivity[]
  reminders            Reminder[]
  dashboardLayouts     DashboardLayout[]
  analyticsSnapshots   AnalyticsSnapshot[]
  productivityLogs     ProductivityLog[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PROFILE
// ─────────────────────────────────────────────

model Profile {
  id             String   @id @default(cuid())
  userId         String   @unique
  name           String
  bio            String?
  avatarUrl      String?
  logoUrl        String?
  githubUsername String?
  linkedinUrl    String?
  backupEmail    String?
  socialLinks    Json?
  notifEmail     Boolean  @default(true)
  notifTelegram  Boolean  @default(false)
  telegramChatId String?
  reminderTime   String   @default("09:00")
  telegramNotifInterval Int @default(1)
  lastTelegramSent      DateTime?
  telegramLinkToken  String?
  telegramLinkExpiry DateTime?
  leetcodeUsername   String?
  gfgUsername        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// DASHBOARD
// ─────────────────────────────────────────────

model DashboardLayout {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("Default")
  isDefault Boolean  @default(false)
  layout    Json     // react-grid-layout layout array
  widgets   Json     // widget config { id, type, visible, config }[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// DSA
// ─────────────────────────────────────────────

enum DsaPlatform {
  LEETCODE
  GFG
  CODEFORCES
  CODECHEF
  HACKERRANK
}

enum DsaDifficulty {
  EASY
  MEDIUM
  HARD
}

enum DsaTopic {
  ARRAYS
  STRINGS
  HASHING
  LINKED_LIST
  STACK
  QUEUE
  TREE
  BST
  HEAP
  GRAPH
  DP
  GREEDY
  BACKTRACKING
  TRIE
  SEGMENT_TREE
  BINARY_SEARCH
  SLIDING_WINDOW
  TWO_POINTERS
}

model DsaProblem {
  id             String        @id @default(cuid())
  userId         String
  name           String
  difficulty     DsaDifficulty
  platform       DsaPlatform
  problemUrl     String?
  solutionUrl    String?
  code           String?       // solution code
  videoLinks     String[]      // YouTube/video links
  notes          String?
  tags           String[]
  topics         DsaTopic[]
  personalRating Int?          @db.SmallInt // 1-5
  timeTaken      Int?          // minutes
  mistakes       String?
  solvedAt       DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions      DsaRevision[]

  @@index([userId])
}

model DsaRevision {
  id          String     @id @default(cuid())
  problemId   String
  dueDate     DateTime
  completedAt DateTime?
  dayInterval Int        // 1, 3, 7, 15, 30, 60, 90
  createdAt   DateTime   @default(now())
  problem     DsaProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// NOTES
// ─────────────────────────────────────────────

model Note {
  id          String          @id @default(cuid())
  userId      String
  title       String
  content     String          @default("")
  category    String?
  folderPath  String?         // e.g. "Backend/NodeJS"
  isPinned    Boolean         @default(false)
  isFavorite  Boolean         @default(false)
  isArchived  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags        NoteTag[]
  attachments NoteAttachment[]

  @@index([userId])
}

model NoteTag {
  id     String @id @default(cuid())
  noteId String
  tag    String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, tag])
}

model NoteAttachment {
  id        String   @id @default(cuid())
  noteId    String
  url       String
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// TASKS / PLANNER
// ─────────────────────────────────────────────

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskScope {
  DAILY
  WEEKLY
  MONTHLY
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  title       String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  scope       TaskScope    @default(DAILY)
  category    String?      // DSA, Backend, DevOps, Blockchain, Placement, Personal, Project
  dueDate     DateTime?
  reminderAt  DateTime?
  isRecurring Boolean      @default(false)
  recurrRule  String?      // cron/rrule expression
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// REMINDERS
// ─────────────────────────────────────────────

enum ReminderType {
  DSA
  SYSTEM_DESIGN
  BACKEND_LEARNING
  GITHUB_PUSH
  JOB_APPLICATION
  BOOK_READING
  CUSTOM
}

model Reminder {
  id        String       @id @default(cuid())
  userId    String
  type      ReminderType
  channels  String[]     // ["EMAIL", "TELEGRAM"]
  message   String
  cronExpr  String
  isActive  Boolean      @default(true)
  lastSent  DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// JOB TRACKER
// ─────────────────────────────────────────────

enum JobStatus {
  WISHLIST
  APPLIED
  OA
  INTERVIEW
  REJECTED
  OFFER
  SELECTED
}

model Job {
  id          String    @id @default(cuid())
  userId      String
  company     String
  role        String
  jobUrl      String?
  status      JobStatus @default(APPLIED)
  appliedDate DateTime  @default(now())
  location    String?
  salary      String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// LEARNING HUB
// ─────────────────────────────────────────────

enum LearningCategory {
  BACKEND
  DEVOPS
  BLOCKCHAIN
  AUTOMATION
  SYSTEM_DESIGN
  AI
}

enum LearningResourceType {
  NOTE
  VIDEO
  ARTICLE
  PDF
  IMAGE
  CHEAT_SHEET
  PROJECT
  ROADMAP
}

model LearningEntry {
  id          String               @id @default(cuid())
  userId      String
  title       String
  category    LearningCategory
  type        LearningResourceType
  content     String?
  url         String?
  fileUrl     String?
  tags        String[]
  durationMin Int?                 // minutes spent
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// RESOURCE VAULT
// ─────────────────────────────────────────────

enum ResourceType {
  YOUTUBE
  WEBSITE
  PDF
  IMAGE
  COURSE
  PLAYLIST
  BLOG
  DOCUMENTATION
  CHEAT_SHEET
}

model ResourceFolder {
  id        String           @id @default(cuid())
  userId    String
  name      String
  parentId  String?
  createdAt DateTime         @default(now())
  resources Resource[]
  children  ResourceFolder[] @relation("FolderHierarchy")
  parent    ResourceFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Resource {
  id          String          @id @default(cuid())
  userId      String
  title       String
  type        ResourceType
  url         String?
  fileUrl     String?
  folderId    String?
  tags        String[]
  description String?
  status      String          @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  isFavorite  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder      ResourceFolder? @relation(fields: [folderId], references: [id])

  @@index([userId])
}

// ─────────────────────────────────────────────
// PLACEMENT PREP
// ─────────────────────────────────────────────

enum PlacementSection {
  DBMS
  OS
  CN
  OOP
  SYSTEM_DESIGN
  APTITUDE
  QUANT
  REASONING
  VERBAL
  HR
  INTERVIEW_EXPERIENCE
}

enum PlacementResourceType {
  NOTE
  PDF
  IMAGE
  FLASHCARD
  IMPORTANT_QUESTION
}

model PlacementNote {
  id         String                @id @default(cuid())
  userId     String
  section    PlacementSection
  title      String
  content    String?
  type       PlacementResourceType @default(NOTE)
  fileUrl    String?
  tags       String[]
  isPinned   Boolean               @default(false)
  isFavorite Boolean               @default(false)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// BOOK LIBRARY
// ─────────────────────────────────────────────

enum BookCategory {
  DSA
  BACKEND
  DEVOPS
  BLOCKCHAIN
  SYSTEM_DESIGN
  PRODUCTIVITY
}

enum ReadingStatus {
  WANT_TO_READ
  READING
  COMPLETED
  PAUSED
}

model Book {
  id            String        @id @default(cuid())
  userId        String
  title         String
  author        String?
  category      BookCategory
  coverUrl      String?
  fileUrl       String?
  notes         String?
  highlights    String?
  totalPages    Int?
  currentPage   Int           @default(0)
  readingStatus ReadingStatus @default(WANT_TO_READ)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// GITHUB TRACKER
// ─────────────────────────────────────────────

model GithubActivity {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @db.Date
  commits      Int      @default(0)
  repositories String[]
  features     String?
  bugsFix      String?
  upcomingWork String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─────────────────────────────────────────────
// PRODUCTIVITY TRACKER
// ─────────────────────────────────────────────

model ProductivityLog {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date
  studyMinutes    Int      @default(0)
  codingMinutes   Int      @default(0)
  projectMinutes  Int      @default(0)
  readingMinutes  Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─────────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────────

model AnalyticsSnapshot {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date
  dsaSolved       Int      @default(0)
  revisionsCount  Int      @default(0)
  learningMinutes Int      @default(0)
  githubCommits   Int      @default(0)
  tasksCompleted  Int      @default(0)
  jobsApplied     Int      @default(0)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─────────────────────────────────────────────
// DSA DAILY GOAL
// ─────────────────────────────────────────────

model DsaDailyGoal {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  completed   Boolean  @default(false)
  solvedCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

